-- 1. inspirations 表添加状态字段
ALTER TABLE inspirations
ADD COLUMN IF NOT EXISTS converted_to_resource_id UUID REFERENCES resources(id) ON DELETE SET NULL,
ADD COLUMN IF NOT EXISTS status TEXT DEFAULT 'active' CHECK (status IN ('active', 'converted', 'archived'));

CREATE INDEX IF NOT EXISTS idx_inspirations_status ON inspirations(status);
CREATE INDEX IF NOT EXISTS idx_inspirations_converted_resource ON inspirations(converted_to_resource_id);

-- 2. resources 表添加来源字段
ALTER TABLE resources
ADD COLUMN IF NOT EXISTS source_inspiration_id UUID REFERENCES inspirations(id) ON DELETE SET NULL;

CREATE INDEX IF NOT EXISTS idx_resources_source_inspiration ON resources(source_inspiration_id);

-- 3. 创建标签分组表
CREATE TABLE IF NOT EXISTS tag_groups (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  name TEXT NOT NULL,
  color TEXT DEFAULT '#3B82F6',
  sort_order INTEGER DEFAULT 0,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_tag_groups_user_id ON tag_groups(user_id);
ALTER TABLE tag_groups ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "Users can manage own tag groups" ON tag_groups;
CREATE POLICY "Users can manage own tag groups" ON tag_groups
  FOR ALL USING (auth.uid() = user_id);

-- 4. 创建获取标签统计的函数
CREATE OR REPLACE FUNCTION get_user_tag_stats(user_uuid UUID)
RETURNS TABLE (tag TEXT, usage_count BIGINT) AS $$
BEGIN
  RETURN QUERY
  SELECT 
    unnest(r.tags) as tag,
    COUNT(*) as usage_count
  FROM resources r
  WHERE r.user_id = user_uuid
    AND r.tags IS NOT NULL 
    AND array_length(r.tags, 1) > 0
  GROUP BY unnest(r.tags)
  ORDER BY usage_count DESC, tag ASC;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- 5. 创建递归获取文件夹资源总数的函数
CREATE OR REPLACE FUNCTION get_folder_resource_count(folder_uuid UUID)
RETURNS INTEGER AS $$
DECLARE
  total_count INTEGER := 0;
  child_folder RECORD;
BEGIN
  SELECT COUNT(*) INTO total_count
  FROM resources
  WHERE folder_id = folder_uuid;
  
  FOR child_folder IN
    SELECT id FROM folders WHERE parent_id = folder_uuid
  LOOP
    total_count := total_count + get_folder_resource_count(child_folder.id);
  END LOOP;
  
  RETURN total_count;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- 6. 创建标签管理函数
CREATE OR REPLACE FUNCTION rename_tag(
  user_uuid UUID,
  old_tag_name TEXT,
  new_tag_name TEXT
)
RETURNS INTEGER AS $$
DECLARE
  affected_rows INTEGER := 0;
BEGIN
  UPDATE resources
  SET tags = array_replace(tags, old_tag_name, new_tag_name)
  WHERE user_id = user_uuid
    AND tags @> ARRAY[old_tag_name];
  
  GET DIAGNOSTICS affected_rows = ROW_COUNT;
  RETURN affected_rows;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

CREATE OR REPLACE FUNCTION delete_tag(
  user_uuid UUID,
  tag_name TEXT
)
RETURNS INTEGER AS $$
DECLARE
  affected_rows INTEGER := 0;
BEGIN
  UPDATE resources
  SET tags = array_remove(tags, tag_name)
  WHERE user_id = user_uuid
    AND tags @> ARRAY[tag_name];
  
  GET DIAGNOSTICS affected_rows = ROW_COUNT;
  RETURN affected_rows;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;